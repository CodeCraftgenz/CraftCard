generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  name                   String
  googleId               String?   @unique @map("google_id")
  passwordHash           String?   @map("password_hash")
  passwordResetToken     String?   @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  avatarUrl              String?   @map("avatar_url")
  totpSecret             String?   @map("totp_secret")
  totpEnabled            Boolean   @default(false) @map("totp_enabled")
  totpBackupCodes        String?   @map("totp_backup_codes") @db.Text
  plan                   String    @default("FREE") // FREE, PRO, BUSINESS, ENTERPRISE
  role                   String    @default("USER") @db.VarChar(20) // USER, ADMIN, SUPER_ADMIN
  apiKey                 String?   @unique @map("api_key") @db.VarChar(64)
  googleCalendarToken    String?   @map("google_calendar_token") @db.Text
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  profiles       Profile[]
  payments       Payment[]
  refreshTokens  RefreshToken[]
  orgMemberships OrganizationMember[]
  achievements      Achievement[]
  pushSubscriptions PushSubscription[]
  webhooks          Webhook[]
  notifications     Notification[]
  tags              Tag[]

  @@index([createdAt])
  @@index([plan])
  @@map("users")
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  displayName String   @map("display_name")
  label       String   @default("Principal") @db.VarChar(50)
  isPrimary   Boolean  @default(true) @map("is_primary")
  bio         String?  @db.Text
  photoUrl    String?  @map("photo_url")
  photoData   String?  @map("photo_data") @db.MediumText
  resumeUrl   String?  @map("resume_url")
  resumeData  String?  @map("resume_data") @db.LongText
  resumeType  String?  @map("resume_type")
  buttonColor String   @default("#00E4F2") @map("button_color")
  slug        String   @unique
  isPublished Boolean  @default(false) @map("is_published")
  viewCount   Int      @default(0) @map("view_count")
  cardTheme   String   @default("default") @map("card_theme")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  coverPhotoUrl  String?  @map("cover_photo_url")
  coverPhotoData String?  @map("cover_photo_data") @db.MediumText

  photoPositionY      Int      @default(50) @map("photo_position_y")
  coverPositionY      Int      @default(50) @map("cover_position_y")

  availabilityStatus  String?  @map("availability_status")
  availabilityMessage String?  @map("availability_message")

  videoUrl            String?  @map("video_url")
  leadCaptureEnabled  Boolean  @default(false) @map("lead_capture_enabled")
  bookingEnabled      Boolean  @default(false) @map("booking_enabled")

  // Visual Customization (Sprint 4)
  fontFamily          String?  @map("font_family")        @db.VarChar(50)
  fontSizeScale       Float?   @default(1.0) @map("font_size_scale")
  backgroundType      String?  @default("theme") @map("background_type") @db.VarChar(20)
  backgroundGradient  String?  @map("background_gradient") @db.VarChar(200)
  backgroundImageUrl  String?  @map("background_image_url") @db.VarChar(500)
  backgroundOverlay   Float?   @default(0.7) @map("background_overlay")
  backgroundPattern   String?  @map("background_pattern") @db.VarChar(30)
  linkStyle           String?  @default("rounded") @map("link_style") @db.VarChar(20)
  linkAnimation       String?  @default("none") @map("link_animation") @db.VarChar(20)
  linkLayout          String?  @default("list") @map("link_layout") @db.VarChar(10)
  iconStyle           String?  @default("default") @map("icon_style") @db.VarChar(20)

  // Bio expandida (Sprint 6)
  location        String?  @db.VarChar(100)
  pronouns        String?  @db.VarChar(30)
  workingHours    String?  @map("working_hours") @db.VarChar(100)
  tagline         String?  @db.VarChar(200)
  sectionsOrder   String?  @map("sections_order") @db.Text

  // Section toggles (user can disable sections even if plan allows)
  resumeEnabled       Boolean @default(true) @map("resume_enabled")
  contactFormEnabled  Boolean @default(true) @map("contact_form_enabled")
  testimonialsEnabled Boolean @default(true) @map("testimonials_enabled")
  galleryEnabled      Boolean @default(true) @map("gallery_enabled")
  servicesEnabled     Boolean @default(true) @map("services_enabled")
  faqEnabled          Boolean @default(true) @map("faq_enabled")
  connectionsEnabled  Boolean @default(true) @map("connections_enabled")

  // B2B - Organization (Sprint 7)
  orgId           String?  @map("org_id")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  socialLinks     SocialLink[]
  profileViews    ProfileView[]
  contactMessages ContactMessage[]
  testimonials    Testimonial[]
  galleryImages   GalleryImage[]
  availableSlots  AvailableSlot[]
  bookings        Booking[]
  services        Service[]
  faqItems        FaqItem[]
  viewEvents      ViewEvent[]
  customFormFields CustomFormField[]
  customDomain    CustomDomain?
  connectionsRequested Connection[] @relation("ConnectionsRequested")
  connectionsReceived  Connection[] @relation("ConnectionsReceived")

  @@index([userId])
  @@index([orgId])
  @@map("profiles")
}

model SocialLink {
  id        String    @id @default(uuid())
  profileId String    @map("profile_id")
  platform  String
  label     String
  url       String
  order     Int       @default(0)
  startsAt  DateTime? @map("starts_at")
  endsAt    DateTime? @map("ends_at")
  linkType  String?   @default("link") @map("link_type") @db.VarChar(20)
  metadata  String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")

  profile    Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  linkClicks LinkClick[]

  @@index([profileId])
  @@map("social_links")
}

model ProfileView {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  date      DateTime @db.Date
  count     Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId])
  @@map("profile_views")
}

model LinkClick {
  id           String     @id @default(uuid())
  socialLinkId String     @map("social_link_id")
  date         DateTime   @db.Date
  count        Int        @default(1)
  createdAt    DateTime   @default(now()) @map("created_at")

  socialLink SocialLink @relation(fields: [socialLinkId], references: [id], onDelete: Cascade)

  @@unique([socialLinkId, date])
  @@index([socialLinkId])
  @@map("link_clicks")
}

model Payment {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  preferenceId   String?   @map("preference_id")
  mpPaymentId    String?   @unique @map("mp_payment_id")
  amount         Decimal   @db.Decimal(10, 2)
  currency       String    @default("BRL")
  status         String    @default("pending")
  plan           String?   @db.VarChar(20)
  billingCycle   String?   @default("YEARLY") @map("billing_cycle") @db.VarChar(10) // MONTHLY | YEARLY
  seatsCount     Int       @default(1) @map("seats_count")
  payerEmail     String?   @map("payer_email")
  mpResponseJson String?   @map("mp_response_json") @db.Text
  paidAt         DateTime? @map("paid_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([payerEmail])
  @@index([paidAt])
  @@map("payments")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ContactMessage {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  senderName  String   @map("sender_name")
  senderEmail String?  @map("sender_email")
  message     String   @db.Text
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, isRead])
  @@map("contact_messages")
}

model GalleryImage {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  imageUrl  String?  @map("image_url")
  imageData String?  @map("image_data") @db.MediumText
  caption   String?  @db.VarChar(200)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("gallery_images")
}

model Testimonial {
  id         String   @id @default(uuid())
  profileId  String   @map("profile_id")
  authorName String   @map("author_name")
  authorRole String?  @map("author_role")
  text       String   @db.Text
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, isApproved])
  @@map("testimonials")
}

model AvailableSlot {
  id        String @id @default(uuid())
  profileId String @map("profile_id")
  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time") @db.VarChar(5)
  endTime   String @map("end_time") @db.VarChar(5)
  duration  Int    @default(30)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, dayOfWeek])
  @@map("available_slots")
}

model Booking {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  name      String
  email     String
  phone     String?
  date      DateTime @db.Date
  time      String   @db.VarChar(5)
  status         String   @default("pending")
  notes          String?  @db.Text
  googleEventId  String?  @map("google_event_id") @db.VarChar(200)
  reminderSentAt DateTime? @map("reminder_sent_at")
  createdAt      DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, date])
  @@map("bookings")
}

model Service {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  title       String   @db.VarChar(150)
  description String?  @db.Text
  price       String?  @db.VarChar(50)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("services")
}

model FaqItem {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  question  String   @db.VarChar(300)
  answer    String   @db.Text
  order     Int      @default(0)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("faq_items")
}

// --- Gamification: Achievements (Sprint 9) ---

model Achievement {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String   @db.VarChar(50)
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("achievements")
}

// --- Analytics: View Events (Sprint 8) ---

model ViewEvent {
  id         String   @id @default(uuid())
  profileId  String   @map("profile_id")
  timestamp  DateTime @default(now())
  country    String?  @db.VarChar(50)
  city       String?  @db.VarChar(100)
  device     String?  @db.VarChar(20)  // mobile, desktop, tablet
  browser    String?  @db.VarChar(30)
  referrer   String?  @db.VarChar(100)
  utmSource  String?  @map("utm_source") @db.VarChar(100)
  utmMedium  String?  @map("utm_medium") @db.VarChar(100)
  utmCampaign String? @map("utm_campaign") @db.VarChar(100)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, timestamp])
  @@index([profileId, referrer])
  @@map("view_events")
}

// --- B2B: Organizations (Sprint 7) ---

model Organization {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(150)
  slug           String   @unique @db.VarChar(100)
  logoUrl        String?  @map("logo_url") @db.VarChar(500)
  primaryColor   String   @default("#00E4F2") @map("primary_color") @db.VarChar(9)
  secondaryColor String   @default("#D12BF2") @map("secondary_color") @db.VarChar(9)
  fontFamily     String   @default("Inter") @map("font_family") @db.VarChar(50)
  domain         String?  @db.VarChar(200)
  maxMembers     Int      @default(10) @map("max_members")
  extraSeats     Int      @default(0) @map("extra_seats")
  brandingActive     Boolean  @default(false) @map("branding_active")
  cardTheme          String?  @default("default") @map("card_theme") @db.VarChar(20)
  linkStyle          String?  @default("rounded") @map("link_style") @db.VarChar(20)
  linkAnimation      String?  @default("none") @map("link_animation") @db.VarChar(20)
  linkLayout         String?  @default("list") @map("link_layout") @db.VarChar(10)
  iconStyle          String?  @default("default") @map("icon_style") @db.VarChar(20)
  backgroundType     String?  @default("theme") @map("background_type") @db.VarChar(20)
  backgroundGradient String?  @map("background_gradient") @db.VarChar(200)
  coverUrl           String?  @map("cover_url") @db.VarChar(500)
  backgroundImageUrl String?  @map("background_image_url") @db.VarChar(500)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  members  OrganizationMember[]
  invites  OrganizationInvite[]
  profiles Profile[]

  @@map("organizations")
}

model OrganizationMember {
  id       String   @id @default(uuid())
  orgId    String   @map("org_id")
  userId   String   @map("user_id")
  role     String   @default("MEMBER") @db.VarChar(20) // OWNER, ADMIN, MEMBER
  joinedAt DateTime @default(now()) @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationInvite {
  id        String    @id @default(uuid())
  orgId     String    @map("org_id")
  email     String    @db.VarChar(255)
  role      String    @default("MEMBER") @db.VarChar(20)
  token     String    @unique @db.VarChar(100)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("organization_invites")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.VarChar(200)
  auth      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Webhook {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  url       String   @db.VarChar(500)
  events    String   @db.Text // JSON array: ["new_message","new_booking","new_testimonial","new_view","lead_status_changed"]
  secret    String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs WebhookLog[]

  @@index([userId])
  @@map("webhooks")
}

model WebhookLog {
  id         String   @id @default(uuid())
  webhookId  String   @map("webhook_id")
  event      String   @db.VarChar(50)
  statusCode Int?     @map("status_code")
  success    Boolean  @default(false)
  error      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_logs")
}

model CustomFormField {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  label     String   @db.VarChar(100)
  type      String   @db.VarChar(20) // text, email, phone, select, textarea, date
  options   String?  @db.Text // JSON for select options
  required  Boolean  @default(false)
  order     Int      @default(0)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("custom_form_fields")
}

model CustomDomain {
  id          String   @id @default(uuid())
  profileId   String   @unique @map("profile_id")
  domain      String   @unique @db.VarChar(255)
  verified    Boolean  @default(false)
  verifyToken String   @map("verify_token") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("custom_domains")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(30)
  title     String   @db.VarChar(200)
  message   String   @db.Text
  metadata  String?  @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Connection {
  id            String    @id @default(uuid())
  requesterId   String    @map("requester_id")
  addresseeId   String    @map("addressee_id")
  status        String    @default("PENDING") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  acceptedAt    DateTime? @map("accepted_at")
  latitude      Float?
  longitude     Float?
  locationLabel String?   @map("location_label") @db.VarChar(200)
  eventId       String?   @map("event_id")

  requester Profile @relation("ConnectionsRequested", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee Profile @relation("ConnectionsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  tags      ConnectionTag[]

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@index([eventId])
  @@index([createdAt])
  @@index([acceptedAt])
  @@map("connections")
}

model Event {
  id          String    @id @default(uuid())
  creatorId   String    @map("creator_id")
  name        String    @db.VarChar(200)
  description String?   @db.Text
  coverUrl    String?   @map("cover_url") @db.VarChar(500)
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  location    String?   @db.VarChar(200)
  latitude    Float?
  longitude   Float?
  slug        String    @unique @db.VarChar(100)
  isPublic    Boolean   @default(true) @map("is_public")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  connections Connection[]

  @@index([creatorId])
  @@index([startDate])
  @@map("events")
}

model Tag {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String   @db.VarChar(50)
  color     String?  @db.VarChar(9)
  createdAt DateTime @default(now()) @map("created_at")

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections ConnectionTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model ConnectionTag {
  id           String @id @default(uuid())
  connectionId String @map("connection_id")
  tagId        String @map("tag_id")

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([connectionId, tagId])
  @@map("connection_tags")
}
